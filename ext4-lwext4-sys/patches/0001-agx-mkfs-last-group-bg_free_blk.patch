--- a/src/ext4_mkfs.c
+++ b/src/ext4_mkfs.c
@@ -365,9 +365,6 @@
 		bg_free_blk -= 2;
 		blk_off += aux_info->bg_desc_blocks;
 
-		if (i == (aux_info->groups - 1))
-			bg_free_blk -= aux_info->first_data_block;
-
 		if (has_superblock(info, i)) {
 			bg_start_block++;
 			blk_off += info->bg_desc_reserve_blocks;
@@ -375,6 +372,47 @@
 			bg_free_blk -= aux_info->bg_desc_blocks;
 		}
 
+		/*
+		 * AGX FIX: the last block-group is typically smaller
+		 * than `blocks_per_group` (the device size doesn't
+		 * have to be a multiple of `blocks_per_group`). Our
+		 * `bg_free_blk` math above is "as if every group is
+		 * full size"; for the last group we have to subtract
+		 * the trailing region that doesn't physically exist
+		 * inside this group, otherwise the descriptor's
+		 * free-count is overcounted and disagrees with the
+		 * bitmap that `ext4_fs_init_block_bitmap` lays down
+		 * on first access (it tail-masks past `group_blocks`).
+		 * Without this fix the kernel's
+		 * `ext4_mb_generate_buddy` detects the inconsistency
+		 * on first allocation in the last group and remounts
+		 * read-only.
+		 *
+		 * The original code did `bg_free_blk -=
+		 * first_data_block` here; that's a misnamed proxy
+		 * for the tail truncation (which only happens to
+		 * coincide with `first_data_block == 1` when the
+		 * device size is exactly `groups * blocks_per_group +
+		 * 1`). For real-world sizes the trailing phantom is
+		 * usually thousands of blocks; the original
+		 * subtraction was a placeholder.
+		 */
+		if (i == (aux_info->groups - 1)) {
+			uint64_t total_blocks = ext4_sb_get_blocks_cnt(aux_info->sb);
+			uint64_t first_data = aux_info->first_data_block;
+			uint64_t covered_full_groups =
+				(uint64_t)info->blocks_per_group *
+				((uint64_t)aux_info->groups - 1);
+			/* Real # blocks physically inside the last group */
+			uint64_t real_last_group_blocks = total_blocks -
+							  first_data -
+							  covered_full_groups;
+			uint64_t phantom = (uint64_t)info->blocks_per_group -
+					   real_last_group_blocks;
+			if (phantom > 0 && phantom <= bg_free_blk)
+				bg_free_blk -= (uint32_t)phantom;
+		}
+
 		ext4_bg_set_block_bitmap(bg_desc, aux_info->sb,
 					 bg_start_block + blk_off + 1);
 
